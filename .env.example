# ── Django ────────────────────────────────────────────────────────────────
# Generate with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=

# False in production. True in development.
DJANGO_DEBUG=False

# Selects the settings module: development | production
# Defaults to development if unset.
DJANGO_ENV=development

# Comma-separated, no spaces. Add your domain(s) before going live.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated full HTTPS origins. Required for HTTPS form POSTs in
# production (Django 4+). Example:
#   CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
CSRF_TRUSTED_ORIGINS=

# ── Database ──────────────────────────────────────────────────────────────
# Production REQUIRES this — production.py raises ImproperlyConfigured if
# unset or malformed. Development falls back to SQLite when this is empty.
# Format: postgres://user:password@host:port/dbname
#
# Native (systemd) deployment — Postgres on the same host:
#   DATABASE_URL=postgres://ecommerce:STRONG_PW@localhost:5432/ecommerce
# Docker compose — Postgres in the `db` service:
#   DATABASE_URL=postgres://ecommerce:STRONG_PW@db:5432/ecommerce
DATABASE_URL=

# Used by docker-compose to initialise the postgres container, AND by
# deployment/scripts/backup.sh. Match them with the user/password/db
# encoded in DATABASE_URL.
POSTGRES_DB=ecommerce
POSTGRES_USER=ecommerce
POSTGRES_PASSWORD=

# ── Redis / Celery ────────────────────────────────────────────────────────
# Native (systemd): Redis is bound to localhost with a requirepass set by
# install.sh. Format: redis://:PASSWORD@localhost:6379/0
# Docker compose: Redis lives in the `redis` service, no password needed
# inside the docker network.
REDIS_URL=redis://:STRONG_PW@localhost:6379/0
CELERY_BROKER_URL=redis://:STRONG_PW@localhost:6379/0
CELERY_RESULT_BACKEND=redis://:STRONG_PW@localhost:6379/0

# ── Email (Gmail SMTP example) ────────────────────────────────────────────
# Generate an app password at https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Restaurant <noreply@example.com>
